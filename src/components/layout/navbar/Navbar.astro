---
import Navgithub from "./Navgithub.astro";
import Navsearch from "./Navsearch.astro";
import Navtheme from "./Navtheme.astro";

const nameLinks = [
  { link: "articles", label: "artigos" },
  { link: "about", label: "sobre" },
];
---

<header
  class="bg-bg-page/70 border-border-ui sticky top-0 z-50 w-full border-b-2 backdrop-blur-md"
>
  <nav
    class="mx-auto grid h-20 max-w-7xl grid-cols-2 items-center px-6 lg:px-10"
    aria-label="Navegação Principal"
  >
    <div class="flex justify-start">
      <a href="/" class="group flex items-center gap-2 outline-none">
        <span
          class="group-hover:text-tx-muted text-lg font-black tracking-tighter uppercase transition-colors"
        >
          my<span class="text-tx-dimmed">.</span>blog
        </span>
      </a>
    </div>

    <div class="flex items-center justify-end gap-3">
      <Navgithub />
      <Navtheme />

      <Navsearch placeholder="Pesquisar por posts..." />
    </div>
  </nav>
</header>
