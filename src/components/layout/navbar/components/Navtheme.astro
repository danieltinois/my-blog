---
import { Icon } from "astro-icon/components";
---

<button
  id="theme-toggle"
  type="button"
  class="border-border-ui bg-bg-ui text-tx-muted hover:bg-bg-ui-hover hover:text-tx-base flex h-9 w-9 items-center justify-center rounded-lg border-2 transition-all duration-300"
  aria-label="Alternar tema"
>
  <Icon name="lucide:sun" class="size-5" id="sun-icon" />

  <Icon name="lucide:moon" class="size-5" id="moon-icon" />
</button>

<script>
  import { rootIsDark, syncRootFromPreferences, toggleTheme } from "@lib/theme";

  const updateAllIcons = () => {
    const isDark = rootIsDark();
    document
      .querySelectorAll('[id^="moon-icon"]')
      .forEach((el) => el.classList.toggle("hidden", !isDark));
    document
      .querySelectorAll('[id^="sun-icon"]')
      .forEach((el) => el.classList.toggle("hidden", isDark));
  };

  const handleToggleClick = (e: Event) => {
    toggleTheme();
    updateAllIcons();
  };

  document
    .querySelectorAll("#theme-toggle")
    .forEach((btn) => btn.addEventListener("click", handleToggleClick));

  updateAllIcons();

  document.addEventListener("astro:after-swap", () => {
    syncRootFromPreferences();
    updateAllIcons();
  });

  document.addEventListener("astro:page-load", () => {
    syncRootFromPreferences();
    updateAllIcons();
  });

  window.addEventListener("themechange", updateAllIcons);
</script>
